# ============================================
# Admin เฟอร์นิเจอร์ — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Line OA (get from https://developers.line.biz/console/)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Admin Auth (set any strong secret)
NEXTAUTH_SECRET=your_random_32_char_secret_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# App URL (Vercel will auto-set VERCEL_URL, but set this for Line webhook)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron Secret (protect cron endpoint)
CRON_SECRET=your_cron_secret_here

# Optional: Cloudinary for photo storage (free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Line Login (OAuth) — get from developers.line.biz > Login channel
LINE_LOGIN_CLIENT_ID=your_line_login_channel_id
LINE_LOGIN_CLIENT_SECRET=your_line_login_channel_secret
LINE_LOGIN_REDIRECT_URI=https://your-app.vercel.app/api/auth/line/callback

# JWT Secret for session tokens  
JWT_SECRET=your_jwt_secret_64chars

# Admin Line User IDs (comma-separated for multiple admins)
ADMIN_LINE_USER_IDS=Uxxx,Uyyy

# Google Maps API (ใช้ Geocoding + Distance Matrix + Maps JavaScript)
# เปิดใน console.cloud.google.com: Maps JavaScript API, Geocoding API, Distance Matrix API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key  # server-side only
